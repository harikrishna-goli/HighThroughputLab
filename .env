# Replication user password (must not contain single quotes). Used by streaming replicas.
REPLICATION_PASSWORD=replicapass456
# PostgreSQL Database Credentials
DB_USER=sharduser
DB_PASSWORD=shardpass123
DB_NAME=financial_db
ACCOUNT_CACHE_TTL_SECONDS=15
REDIS_URL=redis://redis:6379/0
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True
